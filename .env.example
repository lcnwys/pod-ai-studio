# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pod_ai_studio?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# ChcyAI API
CHCYAI_BASE_URL="https://api.chcyai.com"
CHCYAI_ACCESS_KEY="AK_your_access_key"
CHCYAI_SECRET_KEY="SK_your_secret_key"

# Callback URL (your server's public URL)
CALLBACK_URL="https://your-domain.com/api/callback"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-change-this"
NEXTAUTH_URL="http://localhost:3000"

# S3 Storage (MinIO or AWS S3)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minio"
S3_SECRET_KEY="minio123"
S3_BUCKET="pod-ai-studio"
S3_REGION="us-east-1"
